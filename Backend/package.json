{
  "name": "Wellness",
  "version": "1.0.0",
  "description": "Wellness backend",
  "license": "ISC",
  "author": "Anurag gupta",
  "type": "commonjs",
  "main": "server.js",
  "scripts": {
    "test": "node --test tests/**/*.test.js",
    "start": "node --use-system-ca server.js",
    "dev": "nodemon server.js",
    "docs:api": "node scripts/buildApiCatalog.js",
    "seed:medical-questions": "node scripts/seedMedicalConditionQuestions.js",
    "seed:wellness-content": "node scripts/seedWellnessContent.js",
    "seed:test-catalog": "node scripts/seedTestCatalog.js",
    "seed:video-testimonials": "node --use-system-ca scripts/seedVideoTestimonials.js",
    "seed:static-pages": "node --use-system-ca scripts/seedStaticPages.js",
    "seed:specializations": "node --use-system-ca scripts/seedSpecializations.js",
                       "seed:programs": "node --use-system-ca scripts/seedProgramCatalog.js",
    "delete:static-pages": "node --use-system-ca scripts/deleteStaticPages.js",
    "seed:diet-plan-catalog": "node scripts/seedDietPlanCatalog.js",
    "seed:wellness-prescriptions": "node --use-system-ca scripts/seedWellnessPrescriptionCatalog.js",
    "seed:launch-questions": "node scripts/seedLaunchQuestions.js",
    "seed:launch-focus-areas": "node scripts/seedLaunchFocusAreas.js",
    "seed:prakruti-assessment": "node scripts/seedPrakrutiAssessment.js",
    "seed:demo-accounts": "node --use-system-ca scripts/seedDemoAccounts.js",
    "migrate": "node migration/migrateAll.js",
    "migrate:meal-tracking-review": "node migration/migrateAll.js --only=17-meal-tracking-review",
    "migrate:meal-tracking-index": "node scripts/ensureMealTrackingCoachIndex.js",
    "migrate:real-people-testimonial-health-concern": "node --use-system-ca scripts/ensureRealPeopleTestimonialHealthConcernIndex.js",
    "table:commitment-letters": "node --use-system-ca tables/createUserCommitmentLetterTable.js",
    "migrate:commitment-letter": "node migration/migrateAll.js --only=24-user-commitment-letter",
    "table:monthly-champions": "node --use-system-ca tables/createMonthlyChampionPostTable.js && node --use-system-ca tables/createMonthlyChampionPostCommentTable.js",
    "migrate:monthly-champions": "node migration/migrateAll.js --only=25-monthly-champions",
    "table:contact-inquiries": "node --use-system-ca tables/createContactInquiryTable.js",
    "migrate:contact-inquiries": "node --use-system-ca migration/migrateAll.js --only=26-contact-inquiries",
    "job:monthly-champions:run": "node --use-system-ca scripts/runMonthlyChampionJob.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1041.0",
    "@aws-sdk/client-s3": "^3.1050.0",
    "@aws-sdk/client-sts": "^3.1041.0",
    "@aws-sdk/lib-dynamodb": "^3.1041.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "pdfkit": "^0.19.1",
    "uuid": "^14.0.0"
  }
}
