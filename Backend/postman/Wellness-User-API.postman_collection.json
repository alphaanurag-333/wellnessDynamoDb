                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Delete Account (phone + OTP)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"{{userPhone}}\",\n  \"phoneCountryCode\": \"{{userPhoneCountryCode}}\",\n  \"otp\": \"{{userOtp}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/delete"
              },
              "response": []
            }
          ]
        }
      ]
    },
    {
      "name": "Water Tracking",
      "description": "User hydration logs (`/api/user/water-tracking`). All routes require Bearer token.\n\n1 glass = 250 ml (default). Store `date` as `YYYY-MM-DD` in the user's local timezone.",
      "item": [
        {
          "name": "Get Summary (today + history)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/water-tracking?days=7&date={{todayDate}}",
              "host": ["{{baseUrl}}"],
              "path": ["user", "water-tracking"],
              "query": [
                { "key": "days", "value": "7", "description": "1–90, default 7" },
                { "key": "date", "value": "{{todayDate}}", "description": "Reference date YYYY-MM-DD (today)" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Daily Goal",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"goalGlasses\": 17\n}"
            },
            "url": "{{baseUrl}}/user/water-tracking/goal"
          },
          "response": []
        },
        {
          "name": "Increment (+1 glass)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"{{todayDate}}\"\n}"
            },
            "url": "{{baseUrl}}/user/water-tracking/increment",
            "description": "Adds one glass for the given date. Omit `date` to use server UTC today."
          },
          "response": []
        },
        {
          "name": "Decrement (-1 glass)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"{{todayDate}}\"\n}"
            },
            "url": "{{baseUrl}}/user/water-tracking/decrement"
          },
          "response": []
        },
        {
          "name": "Set Day Count",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"{{todayDate}}\",\n  \"glassCount\": 12\n}"
            },
            "url": "{{baseUrl}}/user/water-tracking/day",
            "description": "Set exact glass count for a day (0–999)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Consultancy Payment",
      "description": "Checkout, Razorpay/mock payment, and transaction history.",
      "item": [
        {
          "name": "Checkout Preview",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/user/consultancy-payment/checkout-preview?referralCode=",
              "host": ["{{baseUrl}}"],
              "path": ["user", "consultancy-payment", "checkout-preview"],
              "query": [{ "key": "referralCode", "value": "", "description": "Optional valid referral code" }]
            }
          },
          "response": []
        },
        {
          "name": "Create Payment Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  const txnId = json?.data?.transaction?.id;",
                  "  const orderId = json?.data?.payment?.orderId;",
                  "  if (txnId) pm.collectionVariables.set('transactionId', txnId);",
                  "  if (orderId) pm.collectionVariables.set('razorpayOrderId', orderId);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"healthConcernId\": \"PASTE_HEALTH_CONCERN_UUID\",\n  \"referralCode\": \"\",\n  \"paymentMethod\": \"upi\"\n}"
            },
            "url": "{{baseUrl}}/user/consultancy-payment/orders"
          },
          "response": []
        },
        {
          "name": "Verify Payment (mock dev)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactionId\": \"{{transactionId}}\",\n  \"razorpay_order_id\": \"{{razorpayOrderId}}\",\n  \"razorpay_payment_id\": \"pay_mock_test\",\n  \"razorpay_signature\": \"mock\"\n}"
            },
            "url": "{{baseUrl}}/user/consultancy-payment/verify",
            "description": "In dev without Razorpay, mock orders verify with order id starting with order_mock_."
          },
          "response": []
        },
        {
          "name": "My Transaction History",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/user/consultancy-payment/transactions"
          },
          "response": []
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/user/consultancy-payment/transactions/{{transactionId}}"
          },
          "response": []
        }
      ]
    },
