{
  "info": {
    "_postman_id": "wellness-user-api-collection",
    "name": "Wellness Dynamo — User API",
    "description": "Mobile / user-facing API collection.\n\nBase path: `/api`\n\n**Auth flow**\n1. Send registration OTP → Register (or Login OTP / Password login)\n2. `accessToken` and `refreshToken` are saved automatically on successful auth responses.\n3. Protected routes use Bearer `{{accessToken}}`.\n\n**Water tracking**\nPass `date` as `YYYY-MM-DD` in the user's local timezone when logging intake.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level Bearer auth uses {{accessToken}} for protected routes."
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "userEmail", "value": "user@example.com" },
    { "key": "userPhone", "value": "9876543210" },
    { "key": "userPhoneCountryCode", "value": "+91" },
    { "key": "userPassword", "value": "password123" },
    { "key": "userOtp", "value": "123456" },
    { "key": "todayDate", "value": "2026-06-23" },
    { "key": "primaryHealthConcernId", "value": "" },
    { "key": "fcmId", "value": "sample-fcm-device-token" },
    { "key": "transactionId", "value": "" },
    { "key": "razorpayOrderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Server Health",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "description": "User authentication and profile (`/api/user/auth`).",
      "item": [
        {
          "name": "Registration",
          "item": [
            {
              "name": "Send Registration OTP",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"{{userPhone}}\",\n  \"phoneCountryCode\": \"{{userPhoneCountryCode}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/register/otp/send",
                "description": "Send OTP before self-registration. In dev, response may include `debugOtp` when `EXPOSE_OTP_IN_RESPONSE=true`."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json.debugOtp) {",
                      "  pm.collectionVariables.set('userOtp', json.debugOtp);",
                      "  console.log('Saved userOtp from debugOtp');",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Register (JSON)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"otp\": \"{{userOtp}}\",\n  \"name\": \"Test User\",\n  \"email\": \"{{userEmail}}\",\n  \"phone\": \"{{userPhone}}\",\n  \"phoneCountryCode\": \"{{userPhoneCountryCode}}\",\n  \"password\": \"{{userPassword}}\",\n  \"gender\": \"boy\",\n  \"country\": \"India\",\n  \"state\": \"Maharashtra\",\n  \"city\": \"Mumbai\",\n  \"primaryHealthConcern\": \"{{primaryHealthConcernId}}\",\n  \"termsAccepted\": true,\n  \"fcm_id\": \"{{fcmId}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/register",
                "description": "Verify registration OTP and create account. Set `primaryHealthConcern` to a valid HealthConcern id or leave empty string."
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  const json = pm.response.json();",
                      "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                      "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Register (multipart + profile image)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "otp", "value": "{{userOtp}}", "type": "text" },
                    { "key": "name", "value": "Test User", "type": "text" },
                    { "key": "email", "value": "{{userEmail}}", "type": "text" },
                    { "key": "phone", "value": "{{userPhone}}", "type": "text" },
                    { "key": "phoneCountryCode", "value": "{{userPhoneCountryCode}}", "type": "text" },
                    { "key": "password", "value": "{{userPassword}}", "type": "text" },
                    { "key": "termsAccepted", "value": "true", "type": "text" },
                    { "key": "fcm_id", "value": "{{fcmId}}", "type": "text" },
                    { "key": "file", "type": "file", "src": [], "description": "Optional profile image" }
                  ]
                },
                "url": "{{baseUrl}}/user/auth/register"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 201) {",
                      "  const json = pm.response.json();",
                      "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                      "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            }
          ]
        },
        {
          "name": "Login",
          "item": [
            {
              "name": "Login with Password (email)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\",\n  \"fcm_id\": \"{{fcmId}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/login/password"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const json = pm.response.json();",
                      "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                      "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Login with Password (phone)",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"{{userPhone}}\",\n  \"phoneCountryCode\": \"{{userPhoneCountryCode}}\",\n  \"password\": \"{{userPassword}}\",\n  \"fcm_id\": \"{{fcmId}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/login"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const json = pm.response.json();",
                      "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                      "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Send Login OTP",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"{{userPhone}}\",\n  \"phoneCountryCode\": \"{{userPhoneCountryCode}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/otp/send"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "const json = pm.response.json();",
                      "if (json.debugOtp) {",
                      "  pm.collectionVariables.set('userOtp', json.debugOtp);",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Verify Login OTP",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"{{userPhone}}\",\n  \"phoneCountryCode\": \"{{userPhoneCountryCode}}\",\n  \"otp\": \"{{userOtp}}\",\n  \"fcm_id\": \"{{fcmId}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/otp/verify"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const json = pm.response.json();",
                      "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                      "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            },
            {
              "name": "Refresh Token",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/refresh-token"
              },
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "if (pm.response.code === 200) {",
                      "  const json = pm.response.json();",
                      "  if (json.accessToken) pm.collectionVariables.set('accessToken', json.accessToken);",
                      "  if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);",
                      "}"
                    ]
                  }
                }
              ],
              "response": []
            }
          ]
        },
        {
          "name": "Profile",
          "item": [
            {
              "name": "Get My Profile",
              "request": {
                "method": "GET",
                "header": [],
                "url": "{{baseUrl}}/user/auth/me"
              },
              "response": []
            },
            {
              "name": "Update My Profile (JSON)",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"name\": \"Updated Name\",\n  \"city\": \"Pune\",\n  \"fcm_id\": \"{{fcmId}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/me"
              },
              "response": []
            },
            {
              "name": "Update My Profile (multipart + image)",
              "request": {
                "method": "PATCH",
                "header": [],
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    { "key": "name", "value": "Updated Name", "type": "text" },
                    { "key": "city", "value": "Pune", "type": "text" },
                    { "key": "file", "type": "file", "src": [], "description": "Profile image upload field name: file" }
                  ]
                },
                "url": "{{baseUrl}}/user/auth/me"
              },
              "response": []
            }
          ]
        },
        {
          "name": "Delete Account",
          "item": [
            {
              "name": "Send Delete Account OTP",
              "request": {
                "auth": { "type": "noauth" },
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"phone\": \"{{userPhone}}\",\n  \"phoneCountryCode\": \"{{userPhoneCountryCode}}\"\n}"
                },
                "url": "{{baseUrl}}/user/auth/delete/otp/send"
              },
              "event": [
                {
                  "listen": "test",
