            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"hasConditions\": false,\n  \"onMedication\": false,\n  \"pastSurgery\": false,\n  \"hasRestrictions\": false\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/user/paid-onboarding/medical-conditions"
          },
          "response": []
