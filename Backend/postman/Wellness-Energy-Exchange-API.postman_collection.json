        {
          "name": "POST /user/paid-onboarding/profile",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"9999999999\",\n  \"addressLine1\": \"1 Test St\",\n  \"city\": \"Mumbai\",\n  \"state\": \"MH\",\n  \"country\": \"IN\",\n  \"pincode\": \"400001\",\n  \"dietaryPreference\": \"vegetarian\",\n  \"wellnessJourneyFor\": [\"Fat Loss\"]\n}",
