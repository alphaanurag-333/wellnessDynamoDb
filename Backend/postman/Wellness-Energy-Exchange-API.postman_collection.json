{
  "info": {
    "_postman_id": "wellness-energy-exchange-api",
    "name": "Wellness Energy Exchange API",
    "description": "Energy Exchange + Paid Onboarding endpoints (coach + user + admin).\n\nBase: `{{baseUrl}}`\n\nUse `Wellness-API.postman_environment.json` for shared tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "coach / energy-exchange",
      "item": [
        {
          "name": "GET /coach/energy-exchange/programs?userId=:userId",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{coachToken}}" }] },
            "header": [],
            "url": "{{baseUrl}}/coach/energy-exchange/programs?userId={{userId}}"
          },
          "response": []
        },
        {
          "name": "POST /coach/energy-exchange/programs",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{coachToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"title\": \"Personalized Program designed by IRW\",\n  \"programType\": \"Goal based / Lifetime Membership\",\n  \"description\": \"\",\n  \"monthlyAmount\": 200,\n  \"currency\": \"INR\",\n  \"enabled\": true,\n  \"fyDiscounts\": { \"1\": 0, \"2\": 0, \"3\": 5, \"4\": 10 },\n  \"timeBasedDiscount\": null\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/coach/energy-exchange/programs"
          },
          "response": []
        },
        {
          "name": "PATCH /coach/energy-exchange/programs/:id",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{coachToken}}" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"monthlyAmount\": 200,\n  \"fyDiscounts\": { \"1\": 0, \"2\": 5, \"3\": 5, \"4\": 10 }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/coach/energy-exchange/programs/:id"
          },
          "response": []
        },
        {
          "name": "POST /coach/energy-exchange/programs/:id/enable",
