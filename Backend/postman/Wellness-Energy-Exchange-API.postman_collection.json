          },
          "response": []
        },
        {
          "name": "POST /coach/energy-exchange/programs/:id/disable",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{coachToken}}" }] },
            "header": [],
            "url": "{{baseUrl}}/coach/energy-exchange/programs/:id/disable"
          },
          "response": []
