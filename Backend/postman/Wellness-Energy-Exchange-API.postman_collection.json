          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{accessToken}}" }] },
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "heightCm", "value": "170", "type": "text" },
                { "key": "weightKg", "value": "65", "type": "text" },
                { "key": "activityLevel", "value": "moderately_active", "type": "text" },
                { "key": "weight_pic", "type": "file" }
              ]
            },
            "url": "{{baseUrl}}/user/paid-onboarding/body-measurements"
          },
          "response": []
